{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"lib": ["es2015", "es2017", "dom"],
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"moduleResolution": "node",
		"sourceMap": true,
		"outDir": "dist",
		"baseUrl": ".",
		"paths": {
			"*": ["node_modules/*"]
		},
		"typeRoots": ["types", "node_modules/@types"],
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": ["./src/**/*"],
	"exclude": ["src/**/__mocks__/*"]
}
